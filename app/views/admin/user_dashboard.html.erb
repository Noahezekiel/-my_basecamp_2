<!-- Navbar -->
<nav class="navbar navbar-expand-md navbar-dark bg-primary fixed-top shadow-sm px-4 py-3">
  <div class="container-fluid d-flex flex-wrap justify-content-between align-items-center">

    <!-- Logo -->
    <%= link_to user_dashboard_path, class: "navbar-brand d-flex align-items-center" do %>
      <%= image_tag "logo.png", alt: "MyBaseCamp", class: "navbar-logo me-3" %>
    <% end %>

    <!-- Search Bar -->
    <form class="d-none d-md-flex align-items-center search-container me-auto" role="search">
      <input class="form-control me-2" type="search" placeholder="Search..." aria-label="Search">
      <button class="btn btn-outline-primary text-white bg-primary" type="submit">Search</button>
    </form>

    <!-- Nav Links -->
    <div class="d-flex align-items-center gap-3 text-sm ms-md-4 mt-3 mt-md-0">
      <%= link_to 'Home', user_dashboard_path, class: "text-white text-decoration-none fw-semibold" %>
      <%= link_to 'Profile', user_path(current_user), class: "text-white text-decoration-none fw-semibold" %>
      <%= link_to 'Projects', user_dashboard_path, class: "text-white text-decoration-none fw-semibold" %>
      <%= button_to 'Logout', logout_path, method: :delete, class: "btn btn-danger btn-sm fw-semibold" %>
    </div>

  </div>
</nav>

<!-- user Dashboard Content -->
<div class="container mt-5 pt-5">
  <div class="bg-white shadow rounded p-4 mt-5">
    <h1 class="h3 fw-bold mb-4">Welcome, <%= current_user.name %> 👋</h1>

    <p class="text-muted mb-4">This is your personal dashboard. View your projects, manage your profile, and stay on top of your work.</p>

    <div class="row g-4">
      <!-- Projects Box -->
      <div class="col-md-6">
        <div class="p-4 border rounded bg-light">
          <h2 class="h5 fw-semibold mb-2">Your Projects</h2>
          <p class="text-muted">Manage all your current projects in one place.</p>
          <%= link_to 'View All Projects', projects_path, class: "text-primary text-decoration-none fw-semibold" %>
        </div>
      </div>

      <!-- Account Info Box -->
      <div class="col-md-6">
        <div class="p-4 border rounded bg-light">
          <h2 class="h5 fw-semibold mb-2">Account Info</h2>
          <p class="text-muted mb-1">Email: <span class="fw-medium"><%= current_user.email %></span></p>
          <%= link_to 'Edit Profile', edit_user_path(current_user), class: "text-primary text-decoration-none fw-semibold" %>
        </div>
      </div>
    </div>
  </div>
</div>
