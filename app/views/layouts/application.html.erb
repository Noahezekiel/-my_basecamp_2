<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= content_for(:title) || "MyBaseCamp" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="icon" href="/favicon.ico" type="image/x-icon">

    <!-- Import Bootstrap CSS -->
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

  </head>

  <body>
    <% if current_user %>
      <% if current_user.admin? %>
        <!-- Admin Navbar -->
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
          <div class="container-fluid">

            <%= link_to "AdminBaseCamp", dashboard_path, class: "navbar-brand" %>
            
            <%= render "shared/search_form" %>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
              <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
              <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                  <%= link_to "Home", dashboard_path, class: "nav-link" %>
                </li>
                <li class="nav-item">
                  <%= link_to "Profile", edit_user_path(current_user), class: "nav-link" %>
                </li>
                <li class="nav-item">
                  <%= link_to "Projects", projects_path, class: "nav-link" %>
                </li>
                <li class="nav-item">
                  <%= button_to 'Logout', logout_path, method: :delete, class: "btn btn-danger" %>
                </li>
              </ul>
            </div>
          </div>
        </nav>
      <% else %>
        <!-- User Navbar -->
        <nav class="navbar navbar-expand-lg navbar-light bg-light">
          <div class="container-fluid">
            
          <%= link_to "MyBaseCamp", dashboard_path, class: "navbar-brand" %>
            
            <%= render "shared/search_form" %>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
              <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
              <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                  <%= link_to "Home", dashboard_path, class: "nav-link" %>
                </li>
                <li class="nav-item">
                  <%= link_to "Profile", edit_user_path(current_user), class: "nav-link" %>
                </li>
                <li class="nav-item">
                  <%= link_to "Projects", projects_path, class: "nav-link" %>
                </li>
                <li class="nav-item">
                  <%= button_to 'Logout', logout_path, method: :delete, class: "btn btn-danger" %>
                </li>
              </ul>
            </div>
          </div>
        </nav>
      <% end %>
    <% else %>
      <!-- Guest Navbar -->
      <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <div class="container-fluid">
            <%= link_to "MyBaseCamp", root_path, class: "navbar-brand" %>
          

          <!-- Toggle Button for Mobile -->
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#guestNavbar" aria-controls="guestNavbar" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>

          <!-- Nav Links -->
          <div class="collapse navbar-collapse" id="guestNavbar">
            <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
              <li class="nav-item">
                <%= link_to "About Us", about_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "Contact Us", contact_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "Login", login_path, class: "btn btn-outline-primary me-2" %>
              </li>
              <li class="nav-item">
                <%= link_to "Sign Up", new_user_path, class: "btn btn-primary" %>
              </li>
            </ul>
          </div>
        </div>
      </nav>
    <% end %>

    <% flash.each do |key, message| %>
      <div class="alert alert-<%= key == 'notice' ? 'success' : 'danger' %> alert-dismissible fade show" role="alert">
        <%= message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% end %>


    <!-- Main Content -->
    <main class="container mt-5">
      <%= yield %>
    </main>

    <!-- Footer -->
    <%= render "shared/footer" %>

    <!-- Optional: Add Bootstrap JS -->
    <%= javascript_include_tag "application", "data-turbo-track": "reload" %>
  </body>
</html>
