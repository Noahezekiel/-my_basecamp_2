<!-- app/views/projects/new.html.erb -->
# To create a new project.

<%= form_with model: @project, local: true, class: "max-w-lg mx-auto p-6 bg-white shadow-lg rounded-lg" do |form| %>
  <h2 class="text-2xl font-bold text-center mb-6">Create a New Project</h2>
  
  <div class="mb-4">
    <%= form.label :title, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :title, class: "w-full mt-2 p-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500", placeholder: "Project Title" %>
  </div>

  <div class="mb-4">
    <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_area :description, class: "w-full mt-2 p-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500", placeholder: "Project Description", rows: 5 %>
  </div>

  <div class="flex justify-between items-center">
    <%= form.submit "Create Project", class: "w-full py-2 px-4 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 focus:outline-none" %>
  </div>

<% end %>
