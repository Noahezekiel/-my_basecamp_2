<!-- app/views/projects/new.html.erb -->

<!-- Navbar -->
<nav class="bg-blue-600 text-white px-6 py-4 flex justify-between items-center shadow-lg">
  <!-- Logo -->
  <div class="text-2xl font-bold">
    <%= link_to 'MyBaseCamp', user_dashboard_path, class: "hover:underline" %>
  </div>

  <!-- Nav Links -->
  <div class="flex items-center space-x-6">
    <%= link_to 'Home', user_dashboard_path, class: "hover:underline font-medium" %>
    <%= button_to 'Logout', logout_path, method: :delete, class: "bg-red-500 hover:bg-red-600 px-4 py-2 rounded-md font-semibold text-white transition duration-200" %>
  </div>
</nav>

<!-- Main Content -->
<div class="max-w-lg mx-auto mt-10 p-6 bg-white shadow-lg rounded-lg">
  <h2 class="text-3xl font-bold text-center mb-6 text-gray-800">Create a New Project</h2>

  <%= form_with model: @project, local: true do |form| %>
    <div class="mb-5">
      <%= form.label :title, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :title, class: "w-full mt-2 p-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500", placeholder: "Project Title" %>
    </div>

    <div class="mb-5">
      <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :description, class: "w-full mt-2 p-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500", placeholder: "Project Description", rows: 5 %>
    </div>

    <div>
      <%= form.submit "Create Project", class: "w-full py-2 px-4 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 focus:outline-none transition duration-200" %>
    </div>
  <% end %>
</div>
