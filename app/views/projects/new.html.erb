
<!-- Main Content -->
<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">

      <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-5">
          <h2 class="text-center text-primary fw-bold mb-3">Create a New Project</h2>
          <p class="text-center text-muted mb-4">Start something amazing by creating a new project</p>

          <%= form_with model: @project, local: true do |form| %>

            <!-- Title Field -->
            <div class="mb-4">
              <%= form.label :title, class: "form-label fw-semibold" %>
              <%= form.text_field :title, class: "form-control rounded-3 p-2", placeholder: "Project Title" %>
            </div>

            <!-- Description Field -->
            <div class="mb-4">
              <%= form.label :description, class: "form-label fw-semibold" %>
              <%= form.text_area :description, class: "form-control rounded-3 p-2", placeholder: "Project Description", rows: 5 %>
            </div>

            <!-- Submit -->
            <div class="d-grid mt-4">
              <%= form.submit "Create Project", class: "btn btn-primary btn-lg rounded-pill" %>
            </div>

          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>
