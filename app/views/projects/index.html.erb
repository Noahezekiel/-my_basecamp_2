

<!-- Main Content -->
<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-5 fw-bold text-dark">Your Projects</h1>
    <%= link_to 'New Project', new_project_path, class: "btn btn-success btn-lg rounded-pill shadow-sm" %>
  </div>

  <% if @projects.any? %>
    <div class="table-responsive">
      <table class="table table-hover align-middle shadow-sm border rounded-4 overflow-hidden">
        <thead class="table-light">
          <tr>
            <th scope="col">Title</th>
            <th scope="col">Description</th>
            <th scope="col" class="text-center">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @projects.each do |project| %>
            <tr>
              <td class="fw-semibold"><%= project.title %></td>
              <td><%= truncate(project.description, length: 80) %></td>
              <td class="text-center">
                <%= link_to 'Show', project_path(project), class: "btn btn-sm btn-outline-primary me-1" %>
                <%= link_to 'Edit', edit_project_path(project), class: "btn btn-sm btn-outline-warning me-1" %>
                <%= link_to 'Delete', project_path(project), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-sm btn-outline-danger" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="alert alert-info text-center py-4">
      You don't have any projects yet.
    </div>
  <% end %>
</div>
