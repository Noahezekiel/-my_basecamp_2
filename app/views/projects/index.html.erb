<!-- app/views/projects/index.html.erb -->
# List all projects the user is associated with.

<h1 class="text-3xl font-semibold text-center mb-6">Your Projects</h1>

<div class="space-y-4">
  <% @projects.each do |project| %>
    <div class="bg-white p-4 rounded-lg shadow-md">
      <h3 class="text-xl font-semibold"><%= project.title %></h3>
      <p class="text-gray-600 mt-2"><%= project.description %></p>
      <div class="mt-4 flex justify-between">
        <%= link_to 'Show', project_path(project), class: "text-blue-600 hover:underline" %>
        <%= link_to 'Edit', edit_project_path(project), class: "text-yellow-600 hover:underline" %>
        <%= link_to 'Delete', project_path(project), method: :delete, class: "text-red-600 hover:underline" %>
      </div>
    </div>
  <% end %>
</div>

<%= link_to 'Create New Project', new_project_path, class: "mt-6 text-center block text-blue-600 hover:underline" %>
