<!-- app/views/projects/show.html.erb -->

<div class="container my-5">

  <!-- Project Header -->
  <div class="bg-white shadow-sm border rounded p-4 mb-5">
    <h1 class="display-5 fw-bold text-center mb-3"><%= @project.title %></h1>
    <p class="lead text-muted text-center"><%= @project.description %></p>
  </div>

  <!-- Attachments Section -->
  <div class="bg-light p-4 border rounded shadow-sm mb-5">
    <h2 class="h4 mb-4 text-primary">📎 Attachments</h2>

    <!-- Upload form -->
    <div class="mb-4">
      <%= render 'attachments/form' %>
    </div>

    <% if @project.attachments.any? %>
      <div class="list-group">
        <% @project.attachments.each do |attachment| %>
          <div class="list-group-item d-flex justify-content-between align-items-center">
            <div>
              <%= link_to attachment.file.filename.to_s, url_for(attachment.file), class: "fw-semibold text-decoration-none" %>
              <span class="text-muted small ms-2">[<%= attachment.file.content_type %>]</span>
            </div>
            <%= button_to "Delete", project_attachment_path(@project, attachment), method: :delete, class: "btn btn-sm btn-link text-danger", data: { confirm: "Delete this file?" } %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-muted fst-italic">No attachments uploaded yet.</p>
    <% end %>
  </div>

  <!-- Threads Section -->
  <div class="bg-white p-4 border rounded shadow-sm">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="h4 text-success mb-0">💬 Project Threads</h2>
      <% if current_user == @project.user || current_user.admin? %>
        <%= link_to "New Thread", new_project_project_thread_path(@project), class: "btn btn-success" %>
      <% end %>
    </div>

    <% if @project.project_threads.any? %>
      <% @project.threads.each do |thread| %>
        <div class="card mb-3 border-0 shadow-sm">
          <div class="card-body">
            <h5 class="card-title text-dark"><%= thread.title %></h5>
            <p class="card-text text-muted"><%= thread.description %></p>

            <%= link_to "💬 View Messages", project_thread_path(@project, thread), class: "btn btn-outline-primary btn-sm mt-2" %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-muted fst-italic">No threads yet. Be the first to start a discussion!</p>
    <% end %>
  </div>

</div>
