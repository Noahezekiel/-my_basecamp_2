<!-- app/views/projects/show.html.erb -->

<!-- Navbar -->
<nav class="bg-blue-600 text-white px-6 py-4 flex flex-col md:flex-row md:justify-between md:items-center shadow-lg space-y-4 md:space-y-0">
  <!-- Logo -->
  <div class="text-2xl font-bold">
    <%= link_to 'MyBaseCamp', dashboard_path, class: "hover:underline" %>
  </div>

  <!-- Nav Links -->
  <div class="flex items-center space-x-6">
    <%= link_to 'Home', dashboard_path, class: "hover:underline font-medium" %>
    <%= button_to 'Logout', logout_path, method: :delete, class: "bg-red-500 hover:bg-red-600 px-4 py-2 rounded-md font-semibold text-white transition duration-200" %>
  </div>
</nav>

<!-- Main Content -->
<div class="max-w-4xl mx-auto mt-10 p-6 bg-white shadow-md rounded-lg">
  <h1 class="text-3xl font-bold text-center mb-6 text-gray-800"><%= @project.title %></h1>

  <p class="text-gray-700 text-lg mb-6"><%= @project.description %></p>

  <% if current_user == @project.user || current_user.admin? %>
    <div class="flex justify-end space-x-4 mt-6">
      <%= link_to 'Edit', edit_project_path(@project), class: "bg-yellow-400 hover:bg-yellow-500 text-white px-4 py-2 rounded-md font-semibold transition duration-200" %>
      <%= link_to 'Delete', project_path(@project), method: :delete, data: { confirm: "Are you sure you want to delete this project?" }, class: "bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-md font-semibold transition duration-200" %>
    </div>
  <% end %>
</div>

