<div class="container my-5"> 

  <!-- Project Header -->
  <div class="bg-white shadow-sm border rounded p-4 mb-5">
    <h1 class="display-5 fw-bold text-center mb-3"><%= @project.title %></h1>
    <p class="lead text-muted text-center"><%= @project.description %></p>
  </div>

  <!-- Invite Form (visible only to project creator) -->
  <% if current_user == @project.user %>
    <div class="bg-white p-4 border rounded shadow-sm mb-5">
      <h2 class="h5 text-primary">Invite User to Project</h2>
      <%= form_with url: project_project_memberships_path(@project), method: :post, local: true do %>
        <div class="row g-2 align-items-end">
          <div class="col-md-8">
            <%= label_tag :email, "User Email", class: "form-label" %>
            <%= email_field_tag :email, nil, class: "form-control", placeholder: "Enter user email", required: true %>
          </div>
          <div class="col-md-4">
            <%= submit_tag "Invite", class: "btn btn-primary w-100" %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Attachments Section -->
  <div class="bg-light p-4 border rounded shadow-sm mb-5">
    <h2 class="h4 mb-4 text-primary">Attachments</h2>

    <!-- Upload form -->
    <div class="mb-4">
      <%= render 'attachments/form' %>
    </div>

    <% if @project.attachments.any? %>
      <div class="list-group">
        <% @project.attachments.each do |attachment| %>
          <div class="list-group-item d-flex justify-content-between align-items-center">
            <div>
              <%= link_to attachment.file.filename.to_s, url_for(attachment.file), class: "fw-semibold text-decoration-none" %>
              <span class="text-muted small ms-2">[<%= attachment.file.content_type %>]</span>
            </div>
            <%= button_to "Delete", project_attachment_path(@project, attachment), method: :delete, class: "btn btn-sm btn-link text-danger", data: { confirm: "Delete this file?" } %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-muted fst-italic">No attachments uploaded yet.</p>
    <% end %>
  </div>

  <!-- Threads Section -->
  <div class="bg-white p-4 border rounded shadow-sm">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="h4 text-success mb-0">💬 Project Threads</h2>
      <% membership = @project.project_memberships.find_by(user: current_user) %>
      <% if current_user == @project.user || (membership && membership.role == "admin") %>
        <%= link_to "New Thread", new_project_project_thread_path(@project), class: "btn btn-success" %>
      <% end %>
    </div>


    <% if @project.project_threads.any? %>
      <% @project.project_threads.each do |thread| %>
        <div class="card mb-3 border-0 shadow-sm">
          <div class="card-body">
            <h5 class="card-title text-dark"><%= thread.title %></h5>
            <p class="card-text text-muted"><%= thread.description %></p>

            <%= link_to "💬 View Messages", project_project_thread_path(@project, thread), class: "btn btn-outline-primary btn-sm mt-2" %>

            <% if current_user == @project.user || current_user.admin? %>
              <%= link_to "✏️ Edit Thread", edit_project_project_thread_path(@project, thread), class: "btn btn-sm btn-outline-warning me-2" %>
              <%= button_to "🗑️ Delete Thread", project_project_thread_path(@project, thread), method: :delete, data: { confirm: "Are you sure you want to delete this thread?" }, class: "btn btn-sm btn-outline-danger mt-2 ms-2" %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-muted fst-italic">No threads yet. Be the first to start a discussion!</p>
    <% end %>
  </div>

  <!-- Member List -->
  <div class="bg-light p-4 border rounded shadow-sm mt-5">
    <h2 class="h5 text-secondary mb-3">Project Members</h2>
    <ul class="list-group">
      <% @project.project_memberships.includes(:user).each do |membership| %>
        <li class="list-group-item d-flex justify-content-between align-items-center">
          <div>
            <%= membership.user.name %> (<%= membership.user.email %>)
            <span class="badge bg-secondary text-capitalize"><%= membership.role %></span>
          </div>
          <% if current_user == @project.user && membership.user != @project.user %>
            <%= button_to "Remove Member", project_project_membership_path(@project, membership), method: :delete, data: { confirm: "Are you sure you want to remove this member?" }, class: "btn btn-sm btn-outline-danger" %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
</div>
