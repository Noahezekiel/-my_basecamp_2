<!-- app/views/projects/edit.html.erb -->

<!-- Navbar -->
<nav class="bg-blue-600 text-white px-6 py-4 flex justify-between items-center shadow-md">
  <div class="text-2xl font-bold">
    <%= link_to 'MyBaseCamp', dashboard_path, class: "hover:underline" %>
  </div>
  <div class="space-x-4">
    <%= link_to 'Home', dashboard_path, class: "hover:underline" %>
    <%= link_to 'Logout', login_path, class: "hover:underline" %>
  </div>
</nav>

<!-- Edit Project Form -->
<div class="max-w-2xl mx-auto mt-10 px-4">
  <h1 class="text-3xl font-bold text-center text-gray-800 mb-8">Edit Project</h1>

  <%= form_with model: @project, local: true, class: "bg-white p-8 shadow-lg rounded-xl" do |form| %>
    
    <div class="mb-6">
      <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :title, class: "w-full p-3 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500", placeholder: "Enter project title" %>
    </div>

    <div class="mb-6">
      <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_area :description, class: "w-full p-3 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500", placeholder: "Enter project description", rows: 6 %>
    </div>

    <div class="text-center">
      <%= form.submit "Update Project", class: "px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition duration-200" %>
    </div>

  <% end %>
</div>
