<div class="container mt-4">
  <h3>Edit Thread</h3>

  <div class="card">
    <div class="card-body">
      <%= form_with(model: [@project, @project_thread], local: true) do |f| %>
        <div class="mb-3">
          <%= f.label :title, "Thread Title", class: "form-label" %>
          <%= f.text_field :title, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :description, "Thread Description", class: "form-label" %>
          <%= f.text_area :description, class: "form-control", rows: 5 %>
        </div>

        <div class="text-end">
          <%= f.submit "Update Thread", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-3">
    <%= link_to "Back to Project", project_path(@project), class: "btn btn-secondary" %>
  </div>
</div>
