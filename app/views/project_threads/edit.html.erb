<div class="card shadow-sm mt-4">
  <div class="card-header bg-success text-white">
    <h3>Edit Thread</h3>
  </div>
  <div class="card-body">
    <%= form_with(model: [@project, @project_thread], local: true) do |f| %>
      <div class="mb-3">
        <%= f.label :title, "Thread Title:", class: "form-label" %>
        <%= f.text_field :title, class: "form-control", value: @project_thread.title %>
      </div>

      <div class="mb-3">
        <%= f.label :description, "Description:", class: "form-label" %>
        <%= f.text_area :description, rows: 5, class: "form-control", value: @project_thread.description %>
      </div>

      <div class="d-flex">
        <%= f.submit "Update Thread", class: "btn btn-success me-2" %>
        <%= link_to "Cancel", project_path(@project), class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
