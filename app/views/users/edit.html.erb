
<!-- User Profile Edit Form -->
<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">

      <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-5">
          <h2 class="text-center text-primary fw-bold mb-4">Edit Your Profile</h2>

          <%= form_with model: @user, local: true do |form| %>

            <!-- Name Field -->
            <div class="mb-4">
              <%= form.label :name, class: "form-label fw-semibold" %>
              <%= form.text_field :name, class: "form-control rounded-3 p-3", placeholder: "Your Name" %>
            </div>

            <!-- Email Field -->
            <div class="mb-4">
              <%= form.label :email, class: "form-label fw-semibold" %>
              <%= form.email_field :email, class: "form-control rounded-3 p-3", placeholder: "you@example.com" %>
            </div>

            <!-- Password Field -->
            <div class="mb-4">
              <%= form.label :password, class: "form-label fw-semibold" %>
              <%= form.password_field :password, class: "form-control rounded-3 p-3", placeholder: "New Password (leave blank to keep current)" %>
            </div>

            <!-- Submit -->
            <div class="d-grid mt-4">
              <%= form.submit "Update Profile", class: "btn btn-primary btn-lg rounded-pill" %>
            </div>

          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>
