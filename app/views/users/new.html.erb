<!-- app/views/users/new.html.erb -->
<!--To create a new user account.-->

<%= form_with model: @user, local: true, class: "max-w-lg mx-auto p-6 bg-white shadow-lg rounded-lg" do |form| %>
  <h2 class="text-2xl font-bold text-center mb-6">Create Your Account</h2>
  
  <div class="mb-4">
    <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :name, class: "w-full mt-2 p-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500", placeholder: "Enter your name" %>
  </div>

  <div class="mb-4">
    <%= form.label :email, class: "block text-sm font-medium text-gray-700" %>
    <%= form.email_field :email, class: "w-full mt-2 p-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500", placeholder: "Enter your email" %>
  </div>

  <div class="mb-4">
    <%= form.label :password, class: "block text-sm font-medium text-gray-700" %>
    <%= form.password_field :password, class: "w-full mt-2 p-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500", placeholder: "Create a password" %>
  </div>

  <div class="mb-4">
    <%= form.label :password_confirmation, class: "block text-sm font-medium text-gray-700" %>
    <%= form.password_field :password_confirmation, class: "w-full mt-2 p-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500", placeholder: "Confirm your password" %>
  </div>

  <div class="flex justify-between items-center">
    <%= form.submit "Sign Up", class: "w-full py-2 px-4 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 focus:outline-none" %>
  </div>
<%= link_to 'Already have an account? Sign In', login_path, class: "block text-center text-blue-600 mt-4 hover:underline" %>
<% end %>

