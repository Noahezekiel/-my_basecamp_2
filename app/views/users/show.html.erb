<!-- app/views/users/show.html.erb -->
# User Permissions (setAdmin & removeAdmin)

<% if current_user.admin? && @user != current_user %>
  <div class="flex justify-center space-x-4 mt-6">
    <% if @user.admin? %>
      <%= button_to 'Remove Admin', remove_admin_user_path(@user), method: :post, class: "py-2 px-4 bg-red-600 text-white rounded-lg hover:bg-red-700" %>
    <% else %>
      <%= button_to 'Make Admin', set_admin_user_path(@user), method: :post, class: "py-2 px-4 bg-green-600 text-white rounded-lg hover:bg-green-700" %>
    <% end %>
  </div>
<% end %>
