<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">

      <div class="card shadow-lg rounded-4 border-0">
        <div class="card-body p-5">

          <h2 class="text-center text-primary fw-bold mb-4">Sign In</h2>
          <p class="text-center text-muted mb-4">Access your MyBaseCamp account</p>

          <%= form_with url: login_path, local: true do |form| %>

            <!-- Email -->
            <div class="mb-3">
              <%= form.label :email, class: "form-label fw-semibold" %>
              <%= form.email_field :email, placeholder: "Enter your email", class: "form-control rounded-3 p-2" %>
            </div>

            <!-- Password -->
            <div class="mb-4">
              <%= form.label :password, class: "form-label fw-semibold" %>
              <%= form.password_field :password, placeholder: "Enter your password", class: "form-control rounded-3 p-2" %>
            </div>

            <!-- Submit -->
            <div class="d-grid">
              <%= form.submit "Sign In", class: "btn btn-primary btn-lg rounded-pill" %>
            </div>

          <% end %>

          <div class="text-center mt-4">
            <%= link_to "Don't have an account? Sign Up", new_user_path, class: "text-decoration-none text-primary fw-semibold" %>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>
