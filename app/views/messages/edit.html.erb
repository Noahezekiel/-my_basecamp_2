<div class="card shadow-sm mt-4">
  <div class="card-header bg-primary text-white">
    <h3>Edit Message</h3>
  </div>
  <div class="card-body">
    <%= form_with(model: [@project, @thread, @message], local: true) do |f| %>
      <div class="mb-3">
        <%= f.label :content, "Edit your message:", class: "form-label" %>
        <%= f.text_area :content, rows: 3, class: "form-control", value: @message.content %>
      </div>

      <div class="d-flex">
        <%= f.submit "Update Message", class: "btn btn-success me-2" %>
        <%= link_to "Cancel", project_project_thread_path(@project, @thread), class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
