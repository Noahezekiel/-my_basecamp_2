<% if current_user %>
  <% if current_user.admin? %>
    <!-- Admin Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
      <div class="container-fluid">
        <%= link_to "AdminBaseCamp", dashboard_path, class: "navbar-brand" %>
        <%= render "shared/search_form" %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item"><%= link_to "Home", dashboard_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Profile", edit_user_path(current_user), class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Projects", projects_path, class: "nav-link" %></li>
            <li class="nav-item"><%= button_to 'Logout', logout_path, method: :delete, class: "btn btn-danger" %></li>
          </ul>
        </div>
      </div>
    </nav>

  <% else %>
    <!-- Regular User Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
      <div class="container-fluid">
        <%= link_to "MyBaseCamp", dashboard_path, class: "navbar-brand" %>
        <%= render "shared/search_form" %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item"><%= link_to "Home", dashboard_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Profile", edit_user_path(current_user), class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Projects", projects_path, class: "nav-link" %></li>
            <li class="nav-item"><%= button_to 'Logout', logout_path, method: :delete, class: "btn btn-danger" %></li>
          </ul>
        </div>
      </div>
    </nav>
  <% end %>

<% else %>
  <!-- Guest Navbar -->
  <nav class="navbar navbar-expand-lg navbar-light bg-light">
    <div class="container-fluid">
      <%= link_to "MyBaseCamp", root_path, class: "navbar-brand" %>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#guestNavbar" aria-controls="guestNavbar" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="guestNavbar">
        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
          <li class="nav-item"><%= link_to "About Us", about_path, class: "nav-link" %></li>
          <li class="nav-item"><%= link_to "Contact Us", contact_path, class: "nav-link" %></li>
          <li class="nav-item"><%= link_to "Login", login_path, class: "btn btn-outline-primary me-2" %></li>
          <li class="nav-item"><%= link_to "Sign Up", new_user_path, class: "btn btn-primary" %></li>
        </ul>
      </div>
    </div>
  </nav>
<% end %>
