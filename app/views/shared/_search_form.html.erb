<!-- app/views/shared/_search_form.html.erb -->
<%= form_with url: search_path, method: :get, local: true, class: "d-flex ms-3" do |form| %>
  <%= form.text_field :query, placeholder: "Search...", class: "form-control me-2" %>
  <%= form.submit "Search", class: "btn btn-outline-success" %>
<% end %>