<% if current_user&.admin? %>
  <!-- Admin Dashboard -->
  <div class="container mt-5">
    <div class="card shadow-sm">
      <div class="card-body">
        <div class="bg-primary text-white p-4 rounded mb-4 shadow-sm">
          <h1 class="h3 mb-2">Welcome to the Admin Dashboard, <%= current_user.name %> 👑</h1>
          <p class="mb-0">
            As an administrator, you have full control over user roles, project management, threads, and more.
            Use the navigation menu to manage the system and ensure everything runs smoothly.
          </p>
        </div>

        <div class="text-muted">
          <ul>
            <li>🔐 <strong>Manage Users:</strong> Assign or revoke admin access, and remove inactive accounts.</li>
            <li>📁 <strong>Oversee Projects:</strong> Monitor all ongoing projects and support your team’s collaboration.</li>
            <li>💬 <strong>Moderate Discussions:</strong> Manage project threads and maintain a productive environment.</li>
          </ul>
          <p class="mt-3">
            Visit the <%= link_to "Users Management Page", admin_users_path, class: "text-decoration-underline" %> to start managing users now.
          </p>
        </div>
      </div>
    </div>
  </div>

<% elsif current_user %>
  <!-- User Dashboard -->
  <div class="container mt-5">
    <div class="card shadow-sm">
      <div class="card-body">
        <h1 class="h3 mb-3">Welcome, <%= current_user.name %> 👋</h1>
        <p class="text-muted mb-4">
          This is your personal dashboard. View your projects, manage your profile, and stay on top of your work.
        </p>

        <div class="row">
          <!-- Projects Box -->
          <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
              <div class="card-body">
                <h5 class="card-title">Your Projects</h5>
                <p class="card-text">Manage all your current projects in one place.</p>
                <%= link_to 'View All Projects', projects_path, class: "btn btn-outline-primary" %>
              </div>
            </div>
          </div>

          <!-- Account Info Box -->
          <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
              <div class="card-body">
                <h5 class="card-title">Account Info</h5>
                <p class="card-text mb-2">Email: <strong><%= current_user.email %></strong></p>
                <%= link_to 'Edit Profile', edit_user_path(current_user), class: "btn btn-outline-secondary" %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

<% else %>
  <!-- Guest View -->
  <div class="text-center py-5">
    <h2>Welcome to MyBaseCamp</h2>
    <p>Please <%= link_to "sign in", new_session_path %> or <%= link_to "register", new_user_path %> to get started.</p>
  </div>
<% end %>
