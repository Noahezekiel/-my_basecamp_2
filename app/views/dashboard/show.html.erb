<% if current_user&.admin? %>
  <!-- Admin Dashboard -->
  <div class="container mt-5">
    <div class="card shadow-sm">
      <div class="card-body">
        <div class="bg-primary text-white p-4 rounded mb-4 shadow-sm">
          <h1 class="h3 mb-2">Welcome to the Admin Dashboard, <%= current_user.name %> 👑</h1>
          <p class="mb-0">
            As an administrator, you have full control over user roles, project management, threads, and more.
            Use the navigation menu to manage the system and ensure everything runs smoothly.
          </p>
        </div>

        <div class="text-muted">
          <ul>
            <li>🔐 <strong>Manage Users:</strong> Assign or revoke admin access, and remove inactive accounts.</li>
            <li>📁 <strong>Oversee Projects:</strong> Monitor all ongoing projects and support your team’s collaboration.</li>
            <li>💬 <strong>Moderate Discussions:</strong> Manage project threads and maintain a productive environment.</li>
          </ul>
          <p class="mt-3">
            Visit the <%= link_to "Users Management Page", admin_users_path, class: "text-decoration-underline" %> to start managing users now.
          </p>
        </div>
      </div>
    </div>
  </div>

<% elsif current_user %>
  <!-- User Dashboard -->
  <div class="container mt-5">
    <div class="card shadow-sm">
      <div class="card-body">
        <h1 class="h3 mb-3">Hey <%= current_user.name %>, welcome to your Basecamp!</h1>
        <p class="text-muted mb-4">
          MyBaseCamp is your shared space to manage projects, collaborate with teammates, and keep everything organized in one place.
        </p>

        <div class="bg-light p-4 rounded shadow-sm mb-3">
          <ul class="mb-0">
            <li>📌 <strong>Projects:</strong> Work together with others and track progress.</li>
            <li>🧵 <strong>Threads:</strong> Keep conversations focused and organized.</li>
            <li>📎 <strong>Attachments:</strong> Upload and access all your project files.</li>
          </ul>
        </div>

        <div class="text-center mt-4">
          <%= link_to 'Go to Projects', projects_path, class: "btn btn-primary btn-lg px-4" %>
        </div>
      </div>
    </div>
  </div>

<% else %>
  <!-- Guest View -->
  <div class="text-center py-5">
    <h2>Welcome to MyBaseCamp</h2>
    <p>Please <%= link_to "sign in", new_session_path %> or <%= link_to "register", new_user_path %> to get started.</p>
  </div>
<% end %>
