<body>
  <!-- Navbar -->
  <nav class="bg-blue-600 text-white px-6 py-4 flex flex-col fixed top-0 md:flex-row md:justify-between md:items-center space-y-4 md:space-y-4">
    <div class="text-2xl font-bold max-w-7xl mx-auto flex items-center">
      <%= link_to 'AdminBaseCamp', admin_dashboard_path, class: "hover:underline" %>
    </div>

    <!-- Search Bar -->
    <div class="w-full md:w-1/2">
      <input type="text" placeholder="Search..." class="w-full px-4 py-2 rounded-md text-black focus:outline-none focus:ring-2 focus:ring-white" />
    </div>

    <!-- Nav Links -->
    <div class="flex items-center space-x-6">
      <%= link_to 'Home', admin_dashboard_path, class: "hover:underline font-medium" %>
      <%= link_to 'Profile', edit_user_path(current_user), class: "hover:underline font-medium" %>
      <%= link_to 'Projects', projects_path, class: "hover:underline font-medium" %>
      
      <%= button_to 'Logout', logout_path, method: :delete, class: "bg-red-500 hover:bg-red-600 px-4 py-2 rounded-md font-semibold text-white transition duration-200" %>
    </div>
  </nav>

  <!-- Flash Messages -->
  <div class="max-w-7xl mx-auto p-4">
    <% flash.each do |key, message| %>
      <div class="mb-4 p-3 text-white rounded-md 
        <%= 'bg-green-500' if key == 'notice' %>
        <%= 'bg-red-500' if key == 'alert' %>
        <%= 'bg-blue-500' if key == 'info' %>">
        <%= message %>
      </div>
    <% end %>
  </div>

  <!-- Admin Dashboard Content -->
  <div class="max-w-7xl mx-auto mt-10 p-6 bg-white shadow-md rounded-lg">
    <h1 class="text-3xl font-bold mb-6">Welcome to the Admin Dashboard, <%= current_user.name %> 👑</h1>
    <p class="text-gray-700 mb-6">Manage users, projects, and other admin tasks below.</p>

    <!-- Users Table -->
    <div class="mb-10">
      <h2 class="text-2xl font-semibold mb-4">Registered Users</h2>
      <table class="min-w-full bg-white border border-gray-300">
        <thead class="bg-gray-100 text-left">
          <tr>
            <th class="py-2 px-4 border-b">Name</th>
            <th class="py-2 px-4 border-b">Email</th>
            <th class="py-2 px-4 border-b">Role</th>
            <th class="py-2 px-4 border-b">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr class="hover:bg-gray-50">
              <td class="py-2 px-4 border-b"><%= user.name %></td>
              <td class="py-2 px-4 border-b"><%= user.email %></td>
              <td class="py-2 px-4 border-b capitalize"><%= user.role %></td>
              <td class="py-2 px-4 border-b space-x-2">
                <%= button_to 'Delete', user_path(user), method: :delete, data: { confirm: "Are you sure?" }, class: "bg-red-500 text-white px-3 py-1 rounded" %>

                <% if user.admin? %>
                  <%= button_to 'Remove Admin', remove_admin_path(user), method: :post, class: "bg-yellow-500 text-white px-3 py-1 rounded" %>
                <% else %>
                  <%= button_to 'Make Admin', set_admin_path(user), method: :post, class: "bg-green-600 text-white px-3 py-1 rounded" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Projects Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      
      <div class="p-4 border rounded-md">
        <h2 class="text-xl font-semibold mb-2">Account Info</h2>
        <p>Email: <%= current_user.email %></p>
        <%= link_to 'Edit Profile', edit_user_path(current_user), class: "text-blue-600 hover:underline" %>
      </div>
    </div>
  </div>
</body>
