<!-- Navbar -->
<nav class="bg-blue-600 text-white px-6 py-4 flex flex-col fixed top-0 md:flex-row md:justify-between md:items-center shadow-lg space-y-4 md:space-y-0 left-0 z-50 ">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <!-- Brand -->
    <div class="text-xl font-bold">
      <%= link_to 'MyBaseCamp', user_dashboard_path, class: "hover:underline" %>
    </div>

    <!-- Search Bar -->
    <div class="hidden md:block w-1/3">
      <input type="text" placeholder="Search..." class="w-full px-3 py-1.5 rounded-md text-black focus:outline-none focus:ring-2 focus:ring-white" />
    </div>

    <!-- Nav Links -->
    <div class="flex items-center space-x-4 text-sm">
      <%= link_to 'Home', user_dashboard_path, class: "hover:underline font-medium" %>
      <%= link_to 'Profile', user_path(current_user), class: "hover:underline font-medium" %>
      <%= link_to 'Projects', user_dashboard_path, class: "hover:underline font-medium" %>
      <%= button_to 'Logout', logout_path, method: :delete, class: "bg-red-500 hover:bg-red-600 px-3 py-1 rounded text-white text-sm font-semibold" %>
    </div>
  </div>
</nav>

<!-- Main Dashboard Content -->
<div class="max-w-5xl mx-auto mt-10 pt-20 p-6 bg-white shadow-md rounded-lg">
  <h1 class="text-3xl font-bold mb-4">Welcome, <%= current_user.name %> 👋</h1>

  <p class="text-gray-700 mb-6">This is your personal dashboard. View your projects, manage your profile, and stay on top of your work.</p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Projects Box -->
    <div class="p-6 bg-gray-50 border border-gray-200 rounded-lg shadow-sm">
      <h2 class="text-xl font-semibold mb-2">Your Projects</h2>
      <p class="text-gray-600">Manage all your current projects in one place.</p>
      <%= link_to 'View All Projects', projects_path, class: "mt-2 inline-block text-blue-600 hover:underline" %>
    </div>

    <!-- Account Info Box -->
    <div class="p-6 bg-gray-50 border border-gray-200 rounded-lg shadow-sm">
      <h2 class="text-xl font-semibold mb-2">Account Info</h2>
      <p class="text-gray-600 mb-1">Email: <span class="font-medium"><%= current_user.email %></span></p>
      <%= link_to 'Edit Profile', edit_user_path(current_user), class: "text-blue-600 hover:underline" %>
    </div>
  </div>
</div>
